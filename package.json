{
	"name": "portfolio-latest",
	"version": "1.0.0",
	"description": "Personal portfolio website built with React, TypeScript, and Vite",
	"keywords": [
		"portfolio",
		"react",
		"typescript",
		"vite"
	],
	"license": "MIT",
	"type": "module",
	"homepage": "https://abdullah-portfolio-dev.vercel.app/",
	"author": {
		"name": "Abdullah Iqbal",
		"url": "https://abdullah-portfolio-dev.vercel.app/"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/Abdullahiqbal2021/portfolio-latest"
	},
	"bugs": {
		"url": "https://github.com/Abdullahiqbal2021/portfolio-latest/issues"
	},
	"scripts": {
		"dev": "vite",
		"build": "tsc -b && vite build",
		"lint": "eslint . --fix --report-unused-disable-directives && pnpm format && pnpm spellcheck",
		"lint:ci": "eslint . --report-unused-disable-directives && prettier --check . && pnpm spellcheck",
		"preview": "vite preview",
		"spellcheck": "cspell . --quiet",
		"format": "prettier --write --log-level silent ."
	},
	"dependencies": {
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"react-icons": "^5.6.0"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^4.7.0",
		"cspell": "^8.19.4",
		"eslint": "^9.39.4",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-prettier": "^5.5.5",
		"eslint-plugin-react": "^7.37.5",
		"eslint-plugin-react-hooks": "^5.2.0",
		"eslint-plugin-react-refresh": "^0.4.26",
		"eslint-plugin-unused-imports": "^4.4.1",
		"globals": "^15.15.0",
		"prettier": "^3.8.3",
		"typescript": "~5.7.3",
		"typescript-eslint": "^8.59.0",
		"vite": "^6.4.2"
	},
	"packageManager": "pnpm@10.33.0"
}
